 "doc_type": "Plano de Retiro",
 "doctype": "Print Format",
 "font": "Default",
 "html": "<style>\n  .pr-wrap { font-family: Arial, sans-serif; max-width: 740px; margin: 0 auto; padding: 24px; color: #1a1a1a; }\n  .pr-header { border-bottom: 3px solid #1e3a5f; padding-bottom: 16px; margin-bottom: 20px; }\n  .pr-titulo { font-size: 22px; font-weight: 700; color: #1e3a5f; margin: 0 0 8px; }\n  .pr-fases { margin-bottom: 10px; }\n  .pr-fase-badge { display: inline-block; background: #e8eef5; color: #1e3a5f; border-radius: 12px; padding: 2px 10px; font-size: 12px; font-weight: 600; margin: 2px 3px 2px 0; }\n  .pr-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 6px 24px; font-size: 13px; }\n  .pr-meta-item { display: flex; gap: 6px; }\n  .pr-meta-label { font-weight: 600; color: #555; white-space: nowrap; }\n  .pr-tema { margin-top: 12px; padding: 10px 14px; background: #f5f8fc; border-left: 3px solid #1e3a5f; font-size: 13px; font-style: italic; }\n  .pr-tema-label { font-style: normal; font-weight: 600; color: #1e3a5f; margin-right: 6px; }\n  .pr-section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #888; margin: 24px 0 8px; }\n  .pr-table { width: 100%; border-collapse: collapse; font-size: 13px; }\n  .pr-table th { background: #1e3a5f; color: #fff; padding: 8px 12px; text-align: left; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }\n  .pr-table td { padding: 8px 12px; border-bottom: 1px solid #e8eaed; vertical-align: top; }\n  .pr-table tbody tr:nth-child(even) td { background: #f8f9fb; }\n  .pr-hora { font-weight: 700; white-space: nowrap; width: 64px; color: #1e3a5f; }\n  .pr-resp { color: #555; width: 160px; }\n  .pr-notas-cell { color: #888; font-size: 12px; font-style: italic; }\n  .pr-notas-block { margin-top: 20px; padding: 10px 14px; background: #fffbf0; border: 1px solid #e8d8a0; border-radius: 4px; font-size: 12px; color: #555; }\n  .pr-footer { margin-top: 28px; padding-top: 10px; border-top: 1px solid #ddd; text-align: center; font-size: 11px; color: #aaa; }\n</style>\n\n<div class=\"pr-wrap\">\n  <div class=\"pr-header\">\n    <h1 class=\"pr-titulo\">{{ doc.titulo }}</h1>\n\n    {% if doc.fases %}\n    <div class=\"pr-fases\">\n      {% for rf in doc.fases %}\n      <span class=\"pr-fase-badge\">{{ rf.fase }}</span>\n      {% endfor %}\n    </div>\n    {% endif %}\n\n    <div class=\"pr-meta\">\n      <div class=\"pr-meta-item\">\n        <span class=\"pr-meta-label\">Data:</span>\n        <span>{{ frappe.format(doc.data, 'Date') }}</span>\n      </div>\n      <div class=\"pr-meta-item\">\n        <span class=\"pr-meta-label\">Local:</span>\n        <span>{{ doc.local or '—' }}</span>\n      </div>\n      <div class=\"pr-meta-item\">\n        <span class=\"pr-meta-label\">Orador:</span>\n        <span>{{ doc.orador or '—' }}</span>\n      </div>\n      <div class=\"pr-meta-item\">\n        <span class=\"pr-meta-label\">Ano Lectivo:</span>\n        <span>{{ doc.ano_lectivo or '—' }}</span>\n      </div>\n    </div>\n\n    {% if doc.tema %}\n    <div class=\"pr-tema\">\n      <span class=\"pr-tema-label\">Tema:</span>{{ doc.tema }}\n    </div>\n    {% endif %}\n  </div>\n\n  {% if doc.programa %}\n  <div class=\"pr-section-title\">Programa do Dia</div>\n  <table class=\"pr-table\">\n    <thead>\n      <tr>\n        <th style=\"width:64px\">Hora</th>\n        <th>Actividade</th>\n        <th style=\"width:160px\">Responsável</th>\n        <th>Notas</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for item in doc.programa %}\n      <tr>\n        <td class=\"pr-hora\">{{ item.hora[:5] if item.hora else '—' }}</td>\n        <td>{{ item.actividade }}</td>\n        <td class=\"pr-resp\">{{ item.responsavel or '—' }}</td>\n        <td class=\"pr-notas-cell\">{{ item.notas or '' }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n  </table>\n  {% endif %}\n\n  {% if doc.notas %}\n  <div class=\"pr-notas-block\"><strong>Notas:</strong> {{ doc.notas }}</div>\n  {% endif %}\n\n  <div class=\"pr-footer\">{{ doc.name }} &nbsp;·&nbsp; Estado: {{ doc.estado }}</div>\n</div>",
 "line_breaks": 0,
