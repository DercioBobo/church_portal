# URL do servidor ERPNext (sem trailing slash).
# Deixar vazio para usar o mesmo servidor que serve o portal (recomendado em produção).
# Exemplo para dev local: NEXT_PUBLIC_FRAPPE_URL=http://localhost:8000
NEXT_PUBLIC_FRAPPE_URL=

# Nome completo da paróquia (exibido no portal)
NEXT_PUBLIC_PARISH_NAME=Paróquia Nossa Senhora de Angola

# Abreviatura da paróquia (exibida no logo)
NEXT_PUBLIC_PARISH_SHORT=PNSA
